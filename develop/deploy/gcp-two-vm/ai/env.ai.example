# AI providers
PINECONE_INDEX_NAME=your-index-name
PINECONE_API_KEY=your-pinecone-api-key
GEMINI_API_KEY=your-gemini-api-key
ROUTER_API_KEY=your-router-api-key
GEMINI_MODEL_NAME=gemini-2.5-flash
ROUTER_MODEL_NAME=gemini-2.5-flash-lite

# Backend private IP inside the same GCP VPC
WAS_BASE_URL=http://10.0.0.4:8080
WAS_TIMEOUT=10.0
INTERNAL_API_KEY=your-internal-api-key

# Runtime
APP_ENV=production
LOG_LEVEL=INFO
CHECKPOINT_DB_PATH=/app/data/checkpoints.sqlite

# Optional tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=capstone-v2
