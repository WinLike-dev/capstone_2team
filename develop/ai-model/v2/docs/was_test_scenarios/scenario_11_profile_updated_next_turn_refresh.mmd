sequenceDiagram
    participant A as "Front / App"
    participant W as "WAS"
    participant E as "FastAPI internal event"
    participant T as "ProfileSyncTracker"
    participant F as "FastAPI /chat"
    participant P as "preprocess"

    A->>W: "프로필 변경 요청"
    W->>W: "프로필 DB 업데이트"
    W->>E: "POST /internal/events/profile-updated"
    E->>T: "user_id, changed_fields, profile_version 기록"
    T-->>E: "tracked_version"
    E-->>W: "success"
    A->>W: "다음 채팅 메시지"
    W->>F: "POST /chat"
    F->>P: "profile_sync_version 비교"
    P->>W: "GET /api/user/profile/{user_id}"
    W-->>P: "최신 user_profile"
    P-->>F: "state.user_profile 갱신"
    F-->>W: "ChatResponse"
    W-->>A: "최신 persona / profile 반영 응답"
