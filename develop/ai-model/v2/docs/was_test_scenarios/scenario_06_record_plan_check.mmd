sequenceDiagram
    participant A as "Front / App"
    participant W as "WAS"
    participant F as "FastAPI /chat"
    participant P as "preprocess"
    participant I as "intent / record"
    participant B as "Background write"

    A->>W: "\"오늘 운동 완료했어\""
    W->>F: "POST /chat"
    F->>P: "today_plan 정보 사용"
    P->>W: "GET /api/plan/today/{user_id}"
    W-->>P: "today_plan"
    F->>I: "is_today 및 item_id 결정"
    I-->>F: "record_type=plan_check"
    F-->>W: "ChatResponse"
    W-->>A: "최종 응답"
    F->>B: "background task 시작"
    B->>W: "PUT /api/plan/check/{user_id}"
    W-->>B: "200 OK"
