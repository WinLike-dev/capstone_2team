sequenceDiagram
    participant A as "Front / App"
    participant W as "WAS"
    participant F as "FastAPI /chat"
    participant G as "generate / persona"
    participant B as "Background write"
    participant C as "Checkpoint state"

    A->>W: "\"좋아, 이대로 진행해줘\""
    W->>F: "POST /chat (same session_id)"
    F->>G: "계획_승인 처리"
    G-->>F: "approval response"
    F-->>W: "ChatResponse"
    W-->>A: "승인 완료 응답"
    F->>B: "session의 proposed_plan 전달"
    B->>W: "POST /api/plan/create/{user_id}"
    W-->>B: "200 OK"
    B->>C: "proposed_plan clear"
    Note over B,C: "WAS 저장 성공 시에만 clear"
