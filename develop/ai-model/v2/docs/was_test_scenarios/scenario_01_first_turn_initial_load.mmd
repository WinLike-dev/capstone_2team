sequenceDiagram
    participant A as "Front / App"
    participant W as "WAS"
    participant F as "FastAPI /chat"
    participant P as "preprocess"
    participant G as "LangGraph"

    A->>W: "첫 메시지 전송"
    W->>W: "session_id 생성 또는 조회"
    W->>F: "POST /chat"
    F->>P: "is_session_start = true"
    P->>W: "GET /api/user/profile/{user_id}"
    W-->>P: "user_profile"
    P->>W: "GET /api/plan/today/{user_id}"
    W-->>P: "today_plan"
    P-->>G: "state.user_profile, state.today_plan 설정"
    G-->>F: "response 생성"
    F-->>W: "ChatResponse"
    W-->>A: "최종 응답"
