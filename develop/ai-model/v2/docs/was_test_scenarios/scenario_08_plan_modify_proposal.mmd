sequenceDiagram
    participant A as "Front / App"
    participant W as "WAS"
    participant F as "FastAPI /chat"
    participant I as "intent"
    participant M as "modify_load"
    participant S as "search"
    participant G as "generate / persona"

    A->>W: "\"운동 계획 조금 바꿔줘\""
    W->>F: "POST /chat"
    F->>I: "intent 분석"
    I-->>F: "수정 + modify_target 결정"
    F->>M: "modify_load"
    alt "운동 수정"
        M->>W: "GET /api/workout-plan/full/{user_id}"
        W-->>M: "full workout plan"
    else "식단 수정"
        M->>W: "GET /api/diet-plan/full/{user_id}"
        W-->>M: "full diet plan"
    end
    M-->>F: "modify_plan_context"
    F->>S: "필요 시 external / web search"
    S-->>F: "search_results"
    F->>G: "수정 후 최종 proposed_plan 생성"
    G-->>F: "response + proposed_plan_action=update"
    F-->>W: "ChatResponse"
    W-->>A: "수정안 제안"
    Note over F: "이 단계에서는 FastAPI -> WAS write 없음"
