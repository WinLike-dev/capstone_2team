sequenceDiagram
    participant A as "Front / App"
    participant W as "WAS"
    participant F as "FastAPI /chat"
    participant I as "intent"
    participant C as "care / search"
    participant G as "generate / persona"

    A->>W: "공감 / 케어 메시지"
