flowchart TD
    subgraph ENTRY["0. Chat Entry"]
        E1["Front / App -> WAS"] --> E2["WAS가 session_id 생성 또는 조회"]
        E2 --> E3["WAS -> FastAPI POST /chat"]
        E3 --> E4["LangGraph checkpoint 조회"]
        E4 --> E5{"새 세션인가?"}
        E5 -->|"예"| E6["초기 state 생성"]
        E5 -->|"아니오"| E7["기존 state 복원"]
    end

    subgraph PREPROCESS["1. 전처리"]
        P1["공통 필드 초기화"] --> P2["대기 중 쓰기 재시도"]
        P2 --> P3{"첫 세션 시작인가?"}
        P3 -->|"예"| P4["사용자 프로필 조회<br/>오늘 플랜 조회"]
        P3 -->|"아니오"| P5{"프로필 sync 버전이 stale인가?"}
        P5 -->|"예"| P6["사용자 프로필 재조회"]
        P5 -->|"아니오"| P7["기존 캐시 상태 유지"]
    end

    subgraph SEARCH["2. 검색"]
        S1["검색어 생성<br/>+ 목표 / 부상 정보 보강"] --> S2["검색어 임베딩"]
        S2 --> S3["병렬 검색<br/>기억 / 중요정보 / 외부지식 / 웹"]
        S3 --> S4["결과 병합 + 중복 제거"]
        S4 --> S5["LLM 검색 품질 평가"]
        S5 -->|"정상"| S6["search_quality = ok"]
        S5 -->|"재시도 가능"| S7["검색어 재작성 후 재검색"]
        S5 -->|"재시도 종료"| S8["search_quality = degraded"]
    end

    subgraph MODIFY["2.5 수정 컨텍스트 로드"]
        M1["수정 대상 확인"] --> M2{"운동인가 식단인가?"}
        M2 -->|"운동"| M3["운동 전체 플랜 조회"]
        M2 -->|"식단"| M4["식단 전체 플랜 조회"]
        M3 --> M5["modify_plan_context 저장"]
        M4 --> M5
        M5 --> M6["검색 / 생성 노드로 컨텍스트 전달"]
    end

    subgraph GENERATE["3. Draft 생성"]
        G1["프롬프트 조합<br/>(공통 + 의도별)"] --> G2["LLM 초안 생성"]
        G2 --> G3["Draft 구조화 계약 파싱"]
        G3 --> G4["draft_response 생성"]
        G4 --> G5{"자기 평가 필요?"}
        G5 -->|"예, 그리고 실패"| G6["부분 보정 / 재시도"]
        G5 -->|"통과"| G7["페르소나 단계로 전달 준비"]
    end

    subgraph PERSONA["4. Persona"]
        R1["선택된 persona 해석<br/>registry.json 기준"] --> R2["페르소나 프롬프트 파일 로드"]
        R2 --> R3["Draft 구성요소 기반<br/>표현 전용 재작성"]
        R3 --> R4["최종 응답 생성<br/>+ resolved_persona_id"]
    end

    subgraph BG["5. Background Tasks"]
        B1["기록 / 프로필 쓰기"] --> B4["사용자 프로필 업데이트"]
        B2["플랜 체크 쓰기"] --> B5["플랜 체크 완료 반영"]
        B3["계획 승인 쓰기"] --> B6{"생성인가 수정인가?"}
        B6 -->|"생성"| B7["새 플랜 생성 API 호출"]
        B6 -->|"수정"| B8["기존 플랜 수정 API 호출"]
    end
