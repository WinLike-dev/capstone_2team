# ─── 서버 기본 설정 ─────────────────────────────────────────────────────
# 실행 환경: development | production | test
NODE_ENV=development

# 서버 포트 (기본값: 5000)
PORT=5000

# 로그 레벨: error | warn | info | http | verbose | debug
LOG_LEVEL=http


# ─── 데이터베이스 (PostgreSQL) ──────────────────────────────────────────
# 형식: postgresql://유저명:비밀번호@호스트:포트/DB명
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/healthcare_db


# ─── JWT 인증 ───────────────────────────────────────────────────────────
# 최소 32자 이상의 랜덤 문자열 사용 권장 (예: openssl rand -hex 32)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d


# ─── CORS (프론트엔드 URL) ──────────────────────────────────────────────
CLIENT_URL=http://localhost:3000


# ─── AI 서버 (FastAPI) ──────────────────────────────────────────────────
AI_SERVER_URL=http://localhost:8000
# AI 서버 응답 타임아웃 (ms)
AI_REQUEST_TIMEOUT=30000
